# Copy this file to .env and fill in your details
# NEVER share your .env file or commit it to GitHub

# Your Gmail address
GMAIL_USER=gatsby.techi@gmail.com

# Gmail App Password (NOT your real Gmail password)
# How to get one:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Search "App passwords" → create one → select "Mail" + "Other"
#   4. Copy the 16-character password and paste it below
GMAIL_PASS=your_16_character_app_password_here

# Port (optional, defaults to 3001)
PORT=3001
